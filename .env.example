# Relaxly Backend Environment Variables Template

# Port configuration
PORT=5000

# MongoDB Connection URI (Atlas connection string)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT Token Secret for Auth (Use a long, random cryptographically secure string)
JWT_SECRET=your_jwt_secret_here

# Cloudinary Configuration for Image Uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Paystack API Keys for Payments
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Email Sending Configuration (Resend API)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@relaxlygh.com

# Legacy Email Configuration (GMail SMTP if used)
EMAIL_USER=your_gmail_user@gmail.com
EMAIL_PASS=your_gmail_app_password

# Client Frontend URL
FRONTEND_URL=http://localhost:3000

# Other Configuration Options
DUPLICATE_BOOKING_WINDOW_MS=432000000
