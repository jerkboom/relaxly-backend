# Relaxly Backend Environment Variables
# Copy this file to .env and fill in all values before starting the server.
# Never commit .env to version control.

# --- Server -------------------------------------------------------------------
PORT=5000
NODE_ENV=production

# --- Database -----------------------------------------------------------------
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# --- Auth ---------------------------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<64-char hex string>

# --- Cloudinary (Image Uploads) -----------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Paystack (Payments) ------------------------------------------------------
# Use sk_test_* for development, sk_live_* for production
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# --- Email (Resend) -----------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@relaxlygh.com

# --- URLs ---------------------------------------------------------------------
FRONTEND_URL=https://relaxlygh.com
ADMIN_URL=https://admin.relaxlygh.com
APP_URL=https://api.relaxlygh.com
CLIENT_URL=https://relaxlygh.com

# --- CORS ---------------------------------------------------------------------
CORS_ORIGINS=https://relaxlygh.com,https://admin.relaxlygh.com

# --- Booking ------------------------------------------------------------------
DUPLICATE_BOOKING_WINDOW_MS=432000000

# --- Twilio SMS (optional — leave blank to disable SMS) -----------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Seed Script Only (not read by the server at runtime) ---------------------
SEED_SUPER_ADMIN_EMAIL=admin@relaxlygh.com
SEED_SUPER_ADMIN_PASSWORD=<strong password>
